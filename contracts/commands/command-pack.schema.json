{
  "schema_version": "0.1",
  "contract_kind": "command-pack",
  "phase": "local_prototype",
  "type": "object",
  "manifest_file_extension": ".cdeck-pack.json",
  "selector_target": "pack_manifest_file",
  "selector_filter": "*.cdeck-pack.json",
  "required": [
    "schema_version",
    "pack_id",
    "pack_release",
    "pack_scope",
    "commanddeck_release_compatibility",
    "owner",
    "commands",
    "permissions",
    "record_policy"
  ],
  "pack_required_fields": [
    "schema_version",
    "pack_id",
    "pack_release",
    "pack_scope",
    "commanddeck_release_compatibility",
    "owner",
    "commands",
    "permissions",
    "record_policy"
  ],
  "release_identity": {
    "commanddeck_product_release_format": "release-X.Y.Z",
    "npm_package_version_format": "X.Y.Z",
    "schema_version_role": "contract_compatibility_not_product_release",
    "pack_release_role": "pack_behavior_version",
    "compatibility_enforcement_rule": "current_commanddeck_release_must_be_within_min_inclusive_max_exclusive_range",
    "incompatible_pack_behavior": "fail_closed_with_setup_message_no_auto_migration",
    "core_pack_role": "versioned_behavior_api_for_custom_packs",
    "core_behavior_compatibility_rule": "no_silent_removal_or_redefinition_within_compatible_release_range",
    "legacy_core_behavior_rule": "preserve_legacy_behavior_or_reject_incompatible_pack_explicitly",
    "allowed_pack_scopes": [
      "commanddeck_core",
      "sourcegrid_company",
      "user_custom",
      "partner_custom",
      "fixture_legacy"
    ],
    "sourcegrid_name_disambiguation": {
      "sourcegrid_company": "SourceGrid-owned company pack published by the hosting company",
      "user_custom": "Jimmy or customer authored workspace pack that may live in sourcegrid-labs but is not SourceGrid core"
    }
  },
  "command_required_fields": [
    "command_id",
    "title",
    "example_utterances",
    "permission_level",
    "route",
    "allowed_effects",
    "forbidden_effects",
    "sources"
  ],
  "optional_pack_fields": ["action_requirements", "targets", "default_environment"],
  "optional_command_fields": ["aliases", "runner_action", "approval_prompt", "target_match"],
  "alias_policy": {
    "scope": "active_command_pack_only",
    "owner": "declaring_command",
    "match_rule": "deterministic_normalized_phrase",
    "semantic_matching_allowed": false,
    "cross_command_duplicate_normalized_phrases_allowed": false,
    "execution_authority": "none_beyond_declared_command_contract",
    "ambiguity_behavior": "reject_pack_or_ask_ccq_before_execution"
  },
  "built_in_command_classes": {
    "calibration": {
      "contract": "contracts/commands/calibration-commands.schema.json",
      "availability": "always_available_before_pack_classification",
      "pack_owned": false,
      "relaxed_grammar_allowed": true,
      "execution_authority": "read_only_help_and_metadata_only"
    }
  },
  "allowed_permission_levels": ["read-only", "draft-only", "approval-required"],
  "allowed_source_roots": ["evals/fixtures/", "local://"],
  "forbidden_command_fields": ["script", "scripts", "shell", "executable", "handler", "env", "secrets"],
  "local_exact_runner": {
    "enabled_for_read_only": true,
    "execution_boundary": "allowlisted_local_runner",
    "runner_action_field": "runner_action",
    "allowed_source_protocol": "local://"
  },
  "custom_pack_enforcement": {
    "default_policy": "deny_by_default",
    "pack_authority": "declare_intents_targets_requirements_and_approved_routes_only",
    "execution_authority": "none_without_commanddeck_policy_and_runner_validation",
    "capability_registry_owner": "commanddeck_core",
    "pack_defined_runner_routes_allowed": false,
    "arbitrary_shell_passthrough_allowed": false,
    "hidden_script_execution_allowed": false,
    "rejection_behavior": {
      "bad_pack_shape": "pack_load_rejected",
      "bad_command_declaration": "command_registration_rejected",
      "unsafe_runtime_request": "execution_blocked_before_side_effects",
      "risky_allowed_request": "explicit_approval_required",
      "fallback_execution_allowed": false
    },
    "audit_event": "pack_command_rejected",
    "audit_contract": "contracts/records/pack-rejection-audit.schema.json",
    "audit_write_rule": "opt_in_local_write_only",
    "audit_default_dir": ".commanddeck/audit/pack-rejections"
  },
  "action_requirements": {
    "schema": "contracts/commands/action-requirements.schema.json",
    "core_requirements": "contracts/commands/core-action-requirements.json",
    "core_runtime_source": "contracts/commands/core-action-requirements.json",
    "pack_extension_allowed": true,
    "pack_runtime_scope": "active_command_pack_only",
    "pack_runtime_authority": "clarification_metadata_only",
    "pack_resume_rule": "resumed_command_must_resolve_to_allowed_active_pack_command",
    "missing_required_slot_behavior": "concept_checking_question"
  },
  "target_registry": {
    "status": "runtime_enabled_for_core_action_object_slots",
    "scope": "active_command_pack_only",
    "target_alias_role": "fills_object_slot_only",
    "target_aliases_hide_actions": false,
    "execution_authority": "none_without_core_action_and_runner_validation",
    "supported_kinds_v1": ["url", "dashboard", "repo", "service", "app", "media"],
    "supported_environments_v1": ["dev", "prod"],
    "duplicate_alias_default": "rejected",
    "duplicate_alias_exception": "same_logical_target_family_dev_prod_with_default_environment",
    "runtime_defaulting_scope_v1": "approval_gated_open_url_or_dashboard_only",
    "runtime_ambiguity_behavior_v1": "ask_ccq_for_one_logical_family_with_two_to_four_safe_choices",
    "homepage_target_expected": true,
    "working_bookmarks_allowed": true,
    "script_per_webpage_required": false
  },
  "forbidden_allowed_effects": [
    "payment",
    "production_deploy",
    "production_restart",
    "migration",
    "customer_data_mutation",
    "public_message",
    "external_party_contact",
    "infrastructure_mutation",
    "secret_write",
    "execute_now",
    "execute_without_approval",
    "external_call",
    "provider_call"
  ],
  "execute_now_enabled": false,
  "real_pack_locations": {
    "sourcegrid": "sourcegrid-labs",
    "partners": "partner repos or configured local command folders",
    "commanddeck_repo": "generic examples and tests only"
  }
}
