{
  "schema_version": "0.1",
  "pack_id": "commanddeck.core.v1",
  "pack_release": "release-0.1.0",
  "pack_scope": "commanddeck_core",
  "commanddeck_release_compatibility": {
    "min": "release-0.1.0",
    "max_exclusive": "release-1.0.0"
  },
  "owner": "command-deck",
  "permissions": "contracts/permissions/permission-levels.json",
  "record_policy": {
    "record_schema": "contracts/records/action-record.schema.json",
    "storage": "opt_in_local_action_record"
  },
  "default_environment": "prod",
  "targets": [
    {
      "target_id": "sourcegrid.dashboard.prod",
      "kind": "dashboard",
      "display_name": "SourceGrid dashboard",
      "aliases": [
        "sourcegrid dashboard",
        "sourcegrid homepage",
        "ops dashboard"
      ],
      "environment": "prod",
      "value": "https://sourcegrid.app/"
    }
  ],
  "commands": [
    {
      "command_id": "core.repo_status",
      "title": "What is the status of this repo?",
      "example_utterances": [
        "What is the status of this repo?",
        "Show repo status."
      ],
      "aliases": [
        "Repo status.",
        "Check repo status.",
        "Git status.",
        "Check git status."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "repo.status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://git/status"]
    },
    {
      "command_id": "core.repo_recent_commits",
      "title": "Show recent commits.",
      "example_utterances": [
        "Show recent commits.",
        "What are the recent commits?"
      ],
      "aliases": [
        "Recent commits.",
        "Check recent commits.",
        "Show git log."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "repo.recent_commits",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://git/log"]
    },
    {
      "command_id": "core.puma_status",
      "title": "Is Puma running?",
      "example_utterances": [
        "Is Puma running?",
        "Check Puma status."
      ],
      "aliases": [
        "Puma status.",
        "Check Puma.",
        "Is Puma up?",
        "Is Rails running?",
        "Is Rails server running?"
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "service.puma_status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://process/puma"]
    },
    {
      "command_id": "core.sidekiq_status",
      "title": "Is Sidekiq running?",
      "example_utterances": [
        "Is Sidekiq running?",
        "Check Sidekiq status."
      ],
      "aliases": [
        "Sidekiq status.",
        "Check Sidekiq.",
        "Is Sidekiq up?",
        "Worker status.",
        "Check worker."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "service.sidekiq_status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://process/sidekiq"]
    },
    {
      "command_id": "core.open_url_target",
      "title": "Open a URL target.",
      "example_utterances": [
        "Open website.",
        "Open webpage."
      ],
      "aliases": [
        "Open target."
      ],
      "permission_level": "approval-required",
      "route": "local.exact_control",
      "runner_action": "workspace.open_url",
      "target_match": {
        "action": "open",
        "target_kinds": ["url", "dashboard"]
      },
      "allowed_effects": ["request_human_approval", "run_allowlisted_local_command_after_approval"],
      "forbidden_effects": ["execute_without_approval", "external_call", "provider_call"],
      "sources": ["local://open/url"],
      "approval_prompt": {
        "target": "resolved URL target in the default browser",
        "action": "open the resolved URL target",
        "risk": "launches a GUI app and may reveal workspace context on screen",
        "expected_record": "action record updated after approval decision"
      }
    },
    {
      "command_id": "core.open_sourcegrid_dashboard",
      "title": "Open the SourceGrid dashboard.",
      "example_utterances": [
        "Open the SourceGrid dashboard.",
        "Open SourceGrid dashboard."
      ],
      "aliases": [
        "Open SourceGrid.",
        "Open dashboard.",
        "Open ops dashboard."
      ],
      "permission_level": "approval-required",
      "route": "local.exact_control",
      "runner_action": "workspace.open_sourcegrid_dashboard",
      "allowed_effects": ["request_human_approval", "run_allowlisted_local_command_after_approval"],
      "forbidden_effects": ["execute_without_approval", "external_call", "provider_call"],
      "sources": ["local://open/sourcegrid-dashboard"],
      "approval_prompt": {
        "target": "SourceGrid dashboard in the default browser",
        "action": "open the dashboard",
        "risk": "launches a GUI app and may reveal workspace context on screen",
        "expected_record": "action record updated after approval decision"
      }
    },
    {
      "command_id": "core.open_commanddeck_repo",
      "title": "Open the CommandDeck repo.",
      "example_utterances": [
        "Open the CommandDeck repo.",
        "Open this repo."
      ],
      "aliases": [
        "Open CommandDeck.",
        "Open repo.",
        "Open current repo."
      ],
      "permission_level": "approval-required",
      "route": "local.exact_control",
      "runner_action": "workspace.open_commanddeck_repo",
      "allowed_effects": ["request_human_approval", "run_allowlisted_local_command_after_approval"],
      "forbidden_effects": ["execute_without_approval", "external_call", "provider_call"],
      "sources": ["local://open/current-repo"],
      "approval_prompt": {
        "target": "current CommandDeck repo in Finder",
        "action": "open the repo",
        "risk": "launches a GUI app and changes local desktop state",
        "expected_record": "action record updated after approval decision"
      }
    }
  ]
}
