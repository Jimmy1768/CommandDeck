        "siri setup",
        "command siri setup",
        "how do i use siri",
        "command how do i use siri",
        "macbook setup",
        "voice setup"
      ],
      "route": "commanddeck.help.siri_surface"
    }
  ],
  "v1_surface_requirements": {
    "primary_voice_adapter": "apple_shortcuts",
    "required_platform_entry": "activate_siri_first",
    "common_wake_phrases": ["hey siri", "siri"],
    "required_runner_hardware": "macbook",
    "capture_surfaces": ["phone", "watch", "glasses", "computer"],
    "runner_surface": "computer"
  }
