{
  "schema_version": "0.1",
  "pack_id": "commanddeck.local-exact.slice2",
  "owner": "command-deck",
  "permissions": "contracts/permissions/permission-levels.json",
  "record_policy": {
    "record_schema": "contracts/records/action-record.schema.json",
    "slice_2_storage": "opt_in_local_action_record"
  },
  "action_requirements": [
    {
      "action": "check",
      "capability_source": "pack",
      "required_slots": ["device_code", "action", "object"],
      "optional_slots": ["context", "end_code"],
      "conditionally_required_slots": [
        {
          "slot": "context",
          "when": "multiple_matching_status_scopes_exist",
          "ccq": "Which workspace or service should I check?"
        }
      ],
      "allowed_target_kinds": ["service", "repo", "data_view"],
      "defaulting_rules": ["current_workspace_allowed_when_it_is_the_only_active_workspace"],
      "risk_tier": "informational",
      "approval_may_be_required": false,
      "missing_required_slot_ccq": "What should I check?"
    }
  ],
  "commands": [
    {
      "command_id": "local.repo_status",
      "title": "What is the status of this repo?",
      "example_utterances": [
        "What is the status of this repo?",
        "Show repo status."
      ],
      "aliases": [
        "Repo status.",
        "Check repo status.",
        "Git status.",
        "Check git status."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "repo.status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://git/status"]
    },
    {
      "command_id": "local.repo_recent_commits",
      "title": "Show recent commits.",
      "example_utterances": [
        "Show recent commits.",
        "What are the recent commits?"
      ],
      "aliases": [
        "Recent commits.",
        "Check recent commits.",
        "Show git log."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "repo.recent_commits",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://git/log"]
    },
    {
      "command_id": "local.puma_status",
      "title": "Is Puma running?",
      "example_utterances": [
        "Is Puma running?",
        "Check Puma status."
      ],
      "aliases": [
        "Puma status.",
        "Check Puma.",
        "Is Puma up?",
        "Is Rails running?",
        "Is Rails server running?"
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "service.puma_status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://process/puma"]
    },
    {
      "command_id": "local.sidekiq_status",
      "title": "Is Sidekiq running?",
      "example_utterances": [
        "Is Sidekiq running?",
        "Check Sidekiq status."
      ],
      "aliases": [
        "Sidekiq status.",
        "Check Sidekiq.",
        "Is Sidekiq up?",
        "Worker status.",
        "Check worker."
      ],
      "permission_level": "read-only",
      "route": "local.exact_read",
      "runner_action": "service.sidekiq_status",
      "allowed_effects": ["read_local_state", "run_allowlisted_local_command"],
      "forbidden_effects": ["state_change", "external_call", "provider_call"],
      "sources": ["local://process/sidekiq"]
    }
  ]
}
