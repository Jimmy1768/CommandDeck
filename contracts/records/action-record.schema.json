{
  "schema_version": "0.1",
  "contract_kind": "action-record",
  "type": "object",
  "allowed_result_statuses": [
    "answered_from_fixture",
    "drafted_fixture_only",
    "blocked_contract_only",
    "blocked_pending_approval",
    "approval_requested",
    "executed_local_allowlisted_action",
    "failed_closed",
    "needs_clarification"
  ],
  "clarification_contract": "contracts/records/concept-checking-question.schema.json",
  "clarification_rule": "needs_clarification_is_not_failure_approval_or_execution",
  "ccq_state_storage_rule": "ccq_state_is_stored_in_local_action_record",
  "ccq_state_persistence_rule": "local_auditable_state_not_durable_memory",
  "ccq_resume_token_rule": "short_lived_one_use_token_validated_from_action_record",
  "ccq_resume_token_concurrency_rule": "atomic_compare_and_set_active_to_terminal_status",
  "ccq_resume_lock_rule": "write_record_resume_uses_short_local_action_record_lock",
  "ccq_resume_lock_stale_after_seconds": 30,
  "required": [
    "record_id",
    "command_id",
    "timestamp",
    "actor_ref",
    "adapter",
    "command_text",
    "interpreted_intent",
    "permission_level",
    "approval_status",
    "route",
    "sources_used",
    "model_provider_route",
    "action_key",
    "approval_request",
    "result",
    "errors",
    "follow_up_owner"
  ],
  "properties": {
    "record_id": { "type": "string" },
    "command_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "actor_ref": { "type": "string" },
    "adapter": { "type": "string" },
    "command_text": { "type": "string" },
    "interpreted_intent": { "type": "string" },
    "permission_level": {
      "enum": ["read-only", "draft-only", "approval-required"]
    },
    "approval_status": {
      "enum": [
        "not_required",
        "required_not_requested",
        "requested_pending",
        "approved",
        "denied",
        "blocked_execute_now_disabled"
      ]
    },
    "route": { "type": "string" },
    "sources_used": { "type": "array", "items": { "type": "string" } },
    "model_provider_route": { "type": ["string", "null"] },
    "action_key": { "type": ["string", "null"] },
    "approval_request": {
      "type": ["object", "null"],
      "required": ["target", "action", "risk", "expected_record"],
      "properties": {
        "target": { "type": "string" },
        "action": { "type": "string" },
        "risk": { "type": "string" },
        "expected_record": { "type": "string" }
      }
    },
    "result": {
      "type": "object",
      "required": ["status", "summary"],
      "properties": {
        "status": { "type": "string" },
        "summary": { "type": "string" },
        "clarification": {
          "type": "object",
          "required": [
            "question",
            "missing_slots",
            "partial_intent",
            "resume_token",
            "resume_token_status",
            "resume_token_expires_at",
            "workspace_ref"
          ],
          "properties": {
            "question": { "type": "string" },
            "missing_slots": {
              "type": "array",
              "items": { "enum": ["device_code", "action", "object", "context", "end_code"] }
            },
            "partial_intent": {
              "type": "object",
              "properties": {
                "device_code": { "type": ["string", "null"] },
                "action": { "type": ["string", "null"] },
                "object": { "type": ["string", "null"] },
                "context": { "type": ["string", "null"] },
                "end_code": { "type": ["string", "null"] }
              }
            },
            "resume_token": { "type": "string" },
            "resume_token_status": {
              "enum": ["active", "used", "expired", "rejected"]
            },
            "resume_token_expires_at": { "type": "string", "format": "date-time" },
            "resume_token_used_at": { "type": ["string", "null"], "format": "date-time" },
            "workspace_ref": { "type": "string" },
            "adapter_session_ref": { "type": ["string", "null"] }
          }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } },
    "follow_up_owner": { "type": ["string", "null"] }
  }
}
