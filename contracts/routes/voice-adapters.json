{
  "schema_version": "0.1",
  "voice_adapters_are_io_surfaces": true,
  "reasoning_owner": "apprelay",
  "command_shell_owner": "command-deck",
  "spoken_command_grammar": {
    "platform_wake_phrase_owner": "platform",
    "preferred_format": "<platform_wake_phrase>, <device_code> <action> <object> [context] [end_code]",
    "default_device_code": "computer",
    "target_runner_for_default_device_code": "command",
    "allowed_device_codes": ["computer", "phone", "watch", "glasses"],
    "required_slots": ["device_code", "action", "object"],
    "optional_slots": ["context", "end_code"],
    "allowed_end_codes": ["activate"],
    "surface_hint_rule": "surface_hint_records_capture_hardware_not_spoken_routing_word",
    "ccq_rule": "missing_required_action_parameters_force_concept_checking_question",
    "approval_rule": "end_code_and_voice_invocation_are_not_approval"
  },
  "adapters": [
    {
      "id": "apple_shortcuts",
      "platform_family": "apple",
      "captures_user_speech": true,
      "can_speak_response_text": true,
      "provides_reasoning": false,
      "requires_apple_intelligence": false,
      "slice_1_status": "contract_only"
    },
    {
      "id": "google_voice",
      "platform_family": "google",
      "captures_user_speech": true,
      "can_speak_response_text": true,
      "provides_reasoning": false,
      "requires_apple_intelligence": false,
      "slice_1_status": "future_adapter_contract"
    }
  ],
  "response_modes": [
    {
      "id": "platform_tts",
      "description": "CommandDeck returns text and the platform adapter speaks it.",
      "phase": "first_voice_phase"
    },
    {
      "id": "apprelay_audio",
      "description": "AppRelay or its selected runtime returns audio for the adapter to play.",
      "phase": "future_phase"
    }
  ]
}
