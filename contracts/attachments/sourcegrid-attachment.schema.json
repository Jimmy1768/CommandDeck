{
  "schema_version": "0.1",
  "contract_kind": "sourcegrid-attachment",
  "attachment_owner": "sourcegrid",
  "billing_owner": "sourcegrid_workspace",
  "commanddeck_stores_payment_data": false,
  "apprelay_cost_owner": "sourcegrid_workspace",
  "apprelay_client_contract": {
    "client_type": "internal_ops_tool",
    "client_key": "commanddeck",
    "purpose": "command_routing_reasoning",
    "tenant_context_source": "sourcegrid_workspace_attachment",
    "normal_tenant_chat_surface": false,
    "model_selection_owner": "apprelay",
    "commanddeck_sends_model_name": false,
    "no_execution_authority": true,
    "no_memory_activation": true,
    "memory_writeback_requires_user_confirmation": true,
    "required_output_contract": "contracts/apprelay/commanddeck-reasoning-response.schema.json"
  },
  "apprelay_scope_proof_contract": {
    "preferred_transport": "sourcegrid_full_proxy",
    "sourcegrid_proxy_mode": "sourcegrid_validates_and_calls_apprelay",
    "short_lived_token_mode_enabled": false,
    "direct_apprelay_call_allowed": false,
    "direct_apprelay_secret_policy": "commanddeck_cli_must_not_store_long_lived_apprelay_signing_secret",
    "runtime_mode": "sourcegrid_internal_ops",
    "required_request_contract": "contracts/apprelay/commanddeck-reasoning-request.schema.json",
    "proxy_lifecycle_contract": "contracts/apprelay/sourcegrid-proxied-reasoning-lifecycle.schema.json",
    "authorization_critical_groups": [
      "request_identity",
      "sourcegrid_scope_proof",
      "active_local_context",
      "authority_constraints",
      "runtime_task"
    ]
  },
  "sourcegrid_credit_gate_scope": [
    "apprelay_reasoning",
    "apprelay_audio",
    "other_sourcegrid_billed_runtime_routes"
  ],
  "not_blocked_by_credit_exhaustion": [
    "voice_capture_surface",
    "platform_tts",
    "local_exact_commands",
    "local_read_commands",
    "local_draft_commands",
    "permitted_local_scripts"
  ],
  "required": [
    "schema_version",
    "status",
    "billing_owner",
    "payment_method_state",
    "apprelay_spend_policy",
    "command_pack_owner_repos"
  ],
  "allowed_statuses": [
    "not_attached",
    "contract_only",
    "attached"
  ],
  "allowed_payment_method_states": [
    "missing",
    "verified",
    "not_required_contract_only"
  ],
  "allowed_apprelay_spend_policies": [
    "disabled_until_payment_verified",
    "contract_only_no_spend",
    "enabled_after_payment_verified"
  ],
  "forbidden_local_payment_fields": [
    "card_number",
    "cvv",
    "cvc",
    "raw_payment_method",
    "payment_token",
    "stripe_secret_key",
    "stripe_publishable_key",
    "stripe_payment_method_id"
  ],
  "owner_repo_role": "command_pack_source_only",
  "sourcegrid_labs_console_role": "primary_commanddeck_pack_management_surface",
  "commanddeck_local_runner_role": "local_validation_and_execution_boundary",
  "console_bridge_contract": "contracts/bridge/sourcegrid-console-bridge.schema.json",
  "phase_1_network_calls_enabled": false,
  "phase_1_apprelay_spend_enabled": false
}
